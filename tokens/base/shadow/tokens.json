{
  "shadow": {
    "none": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "0px",
        "color": "#00000000"
      }
    },
    "xs": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "#091e4224"
      }
    },
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "3px",
        "spread": "1px",
        "color": "#091e4224"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "8px",
        "spread": "-1px",
        "color": "#091e4224"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "16px",
        "spread": "-2px",
        "color": "#091e4224"
      }
    },
    "xl": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "16px",
        "blur": "24px",
        "spread": "-4px",
        "color": "#091e424f"
      }
    }
  }
}
