  "font-weight": {
    "regular": {
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      },
      "$type": "number",
      "$value": 400,
      "$description": "pour les paragraphes génériques afin de contraster avec les titres, et pour le texte de longueur moyenne dans les composants"
    },
    "medium": {
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      },
      "$type": "number",
      "$value": 500,
      "$description": "Pour l'alignement avec l'iconographie. Utilisez cette épaisseur dans la plupart des composants et chaque fois que du texte peut être vu à côté des icônes linéaires."
    },
    "semibold": {
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      },
      "$type": "number",
      "$value": 600,
      "$description": "Pour les titres ou pour souligner certains chiffres (widgets de métriques)"
    },
    "bold": {
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      },
      "$type": "number",
      "$value": 700,
      "$description": "Pour des cas particuliers où un texte doit être différencié ou davantage mis en valeur. Utilisez cette pondération avec parcimonie."
    }
  },
