{
  "name": "@aexae/comete-design-tokens",
  "version": "0.1.2",
  "author": "Comète",
  "type": "module",
  "license": "MIT",
  "description": "Comète design tokens — CSS custom properties (primitives + semantic light/dark).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aexae/comete-design-tokens.git"
  },
  "sideEffects": false,
  "files": [
    "build/css",
    "tokens"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "pnpm clean && tsx build.ts",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/node": "^25.0.3",
    "eslint": "^9.0.0",
    "style-dictionary": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "rimraf": "^6.1.2"
  },
  "exports": {
    "./package.json": "./package.json",
    "./css": "./build/css/comete-tokens.css",
    "./tokens/*": "./tokens/*"
  },
  "publishConfig": {
    "access": "public"
  }
}
